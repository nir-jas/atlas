APP_NAME=Atlas
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1

POSTGRES_DB=atlas
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas_dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://atlas:atlas_dev_password@localhost:5432/atlas

VECTOR_DIMENSIONS=1536
EMBEDDING_PROVIDER=fake
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
LLM_PROVIDER=fake
LLM_MODEL=gpt-5.4
ANSWER_SIMILARITY_SCORE_THRESHOLD=0.0
